{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "local-router config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "listen": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string", "default": "127.0.0.1" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8787 }
      }
    },
    "requireApiKey": { "type": "boolean", "default": true },
    "localApiKeys": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "strategy": { "type": "string", "enum": ["round-robin", "fill-first"], "default": "round-robin" },
    "stickyRequests": { "type": "integer", "minimum": 1, "default": 3 },
    "maxBodyBytes": { "type": "integer", "minimum": 1, "default": 26214400 },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseUrl": { "type": "string", "default": "https://api.openai.com/v1" },
        "timeoutMs": { "type": "integer", "minimum": 1, "default": 600000 }
      }
    },
    "cooldown": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rateLimitSeconds": { "type": "integer", "minimum": 0, "default": 300 },
        "authErrorSeconds": { "type": "integer", "minimum": 0, "default": 3600 },
        "serverErrorSeconds": { "type": "integer", "minimum": 0, "default": 60 }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "logBodies": { "type": "boolean", "default": false },
        "logHeaders": { "type": "boolean", "default": false }
      }
    },
    "accounts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "anyOf": [
          { "required": ["apiKey"] },
          { "required": ["apiKeyEnv"] }
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "apiKey": { "type": "string" },
          "apiKeyEnv": { "type": "string" },
          "priority": { "type": "integer", "minimum": 1, "default": 999 },
          "enabled": { "type": "boolean", "default": true },
          "models": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "allow": { "type": "array", "items": { "type": "string" }, "default": ["*"] },
              "deny": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  },
  "required": ["accounts"]
}
