{
  "listen": {
    "host": "127.0.0.1",
    "port": 8787
  },
  "requireApiKey": true,
  "localApiKeys": ["local-router-key-change-me"],
  "strategy": "round-robin",
  "stickyRequests": 3,
  "maxBodyBytes": 26214400,
  "upstream": {
    "baseUrl": "https://api.openai.com/v1",
    "timeoutMs": 600000
  },
  "cooldown": {
    "rateLimitSeconds": 300,
    "authErrorSeconds": 3600,
    "serverErrorSeconds": 60
  },
  "privacy": {
    "logBodies": false,
    "logHeaders": false
  },
  "accounts": [
    {
      "id": "openai-1",
      "name": "OpenAI Account 1",
      "apiKey": "PASTE_OPENAI_API_KEY_HERE",
      "priority": 1,
      "enabled": true,
      "models": { "allow": ["*"] }
    }
  ]
}
